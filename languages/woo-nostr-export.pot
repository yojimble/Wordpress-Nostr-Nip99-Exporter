#. Plugin Name of the plugin
#: wordpress-nostr-export.php
msgid "WooCommerce Nostr Export"
msgstr ""

#. Description of the plugin
#: wordpress-nostr-export.php
msgid "Export WooCommerce products to Nostr relays as NIP-99 classified listings (kind 30402). Handles simple products, variable products, attributes, and stock levels. Signing is done in the browser — no server-side crypto dependencies required."
msgstr ""

